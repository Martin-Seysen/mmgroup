/** @file mm_vector_v1_mod3.c

 File ``mm_vector_v1_mod3`` contains a precomputed vector ``v_1``
 (with entries taken modulo 3) of the representation of the Monster.
 Then the vector ``v = v_1 * g`` can be used for identifying an
 unknown element ``g`` of the subgroup \f$G_{x0}\f$ of the Monster.

 So the functions in this module are similar to those in
 module ``mm_order.c``, but faster.

 Vector ``v_1`` can be obtained from Table ``MM_VECTOR_V1_MOD3_TABLE``
 in this file. Function ``mm_order_find_Gx0_via_v1_mod3`` computes
 the group element ``g**-1`` from a vector ``v = v_1 * g`` in the
 representation \f$\rho_3\f$ of the Monster. Vector ``v`` must
 be given as in the description of the ``mmgroup.mm_op`` extension.
 The element ``g**-1`` is returned as a word of generators as
 described in file ``mmgroup_generators.h``. It is encoded so that
 inversion of it with function ``mm_group_invert_word`` leads to a
 short encoding of element ``g``.

 For future extensions, we want to separate the access to the
 vector ``v`` from the calculations required to obtain ``g``. It
 would be natural to use coroutines for implementing this concept,
 as in the Python module ``mmgroup.dev.mm_reduce.vector_v1_mod3``;
 but coroutines are not available in C. So we use a state machine
 instead. Here the state is stored in a structure of
 type ``mm_order_find_Gx0_type``.
 Function ``mm_order_find_Gx0_v1_mod3_state`` performs the action
 of the state machine. The user has to enter data obtained from
 vector ``v`` into the state machine.

 The implementation of function ``mm_order_find_Gx0_via_v1_mod3``
 is the basic reference for using the state machine.
 The following code sample briefly describes the operation of
 the state machine.

@code
// Input is a vector v = v_1 * g in the representation of the Monster
// mod 3. Output is the inverse g**-1 of g given as a word of
// generators.

// Initialize structure for state machine
mm_order_find_Gx0_type s;
mm_order_find_Gx0_v1_mod3_state(&s, 0);

// Compute the kernel of part 'A' of vector v. That kernel is of
// dimension 1 and spanned by a type-4 vector w3 in the Leech lattice
// mod 3. Convert w3 to the corresponding vector w2 of type 4 in the
// Leech lattice mod 2, using function gen_leech3to2_type4().
// Store w2 in s.data[0].

mm_order_find_Gx0_v1_mod3_state(&s, 1);
// Transform a copy of part 'A' of vector v with the element of G_x0
// given as a word of generators in s.data[0],...,s.data[s.length-1].
// Watermark the 24 rows of the transformed part 'A' as described
// below, and store the watermarks in s.data[0],...,s.data[23].

mm_order_find_Gx0_v1_mod3_state(&s, 2);
// Here entries s.data[0],...,s.data[s.length-1] describe entries of
// the transformed part 'A' computed in the previous step. Replace
// entry s.data[i] by the corresponding entry of the transformed part.

mm_order_find_Gx0_v1_mod3_state(&s, 3);
// Here entries s.data[0],...,s.data[s.length-1] describe entries of
// the input vector v in *sparse representation*. Replace each entry
// s.data[i] by the corresponding entry of input vector v.

mm_order_find_Gx0_v1_mod3_state(&s, 4);
// Same action as in previous step

mm_order_find_Gx0_v1_mod3_state(&s, 5);
// Now g**-1 is available as a word of generators in
// s.data[0],...,s.data[s.length-1]
@endcode

Remarks

Part 'A' of vector ``v`` has a natural interpretation of a 24 times 24
matrix acting on the Leech lattice mod 3.

Watermark of row ``i`` is a pair ``(d, w)``, where ``d`` is the value
of the diagonal entry of the row; and ``w`` is the weight of the row,
i.e. the number of its nonzero entries. Here we have to
store ``0x100 * d + w`` in ``s.data[i]``. This watermarking is
coarser than the corresponding watermarking in [Sey22], Section 6.
But it still allows us to identify a sufficient number of rows
of matrix 'A'. A value ``d = 3`` is interpreted as ``d = 0``.

Indices of entries of ``v`` or of the transformed part ``A``
in ``s.data`` are given in *sparse representation*.  

*/

/// @cond DO_NOT_DOCUMENT 
#include "mat24_functions.h"
#include "clifford12.h"
#include "mm_reduce.h"   
/// @endcond

   




//  %%GEN h


/**
   @brief Structure for state machine for finding an element of \f$G_{x0}\f$

   This structure is used in file ``mm_vector_v1_mod3.c``. For details
   we refer to the documentation of that file.

*/
struct mm_order_find_Gx0_s {
    int32_t state;      ///< State of state machine
    uint32_t length;    ///< Number of entries in component ``data``
    uint32_t data[24];  ///< Interface to caller
    // Internal data
    /** @private */
    uint32_t len_g;     ///< Length of group element g
    /** @private */
    uint32_t g[12];     ///< Group element g computed so far
    /** @private */
    uint32_t signs;     ///< For internal use
    /** @private */
    struct mm_order_data_Gx0_s *pdata; ///< point to data for evaluation   
};


/**
   @brief typedef for structure ``struct mm_order_find_Gx0_s``
*/
typedef struct mm_order_find_Gx0_s  mm_order_find_Gx0_type;


/**
   @brief Structure for finding an element of \f$G_{x0}\f$ from a vector

   This structure is used in file ``mm_vector_v1_mod3.c``. Data in this
   structure are used to compute an element of the group \f$N_{x0}\f$
   of structure \f$2^{1+24+11}.M_{24}\f$ that transforms the a given
   vector ``v`` to the standard order vector ``v1``.
   
   Part ``WM`` contains hash values of rows of part 'A' of ``v1``.
   The hash value of a row is the sum of the absolute values of the
   entries (mod 3) of the row vector plus 32 times the diagonal element.
   Entry ``WM`` contains hash values of rows [0,1,2,3,4,5,8] of ``v1``.
   From these entries we compute a permutation ``pi`` in a factor group
   \f$M_{24}\f$ that transforms ``v`` to a vector
   in ``v1`` * \f$2^{1+24+11}\f$.
   In the sequel we assume that ``v`` is in that group.

   An entry (Y[k,0],Y[k,1]) describes an entry in the 24 times 24 
   matrix making up part 'A' of the vector ``v1``. The 11
   entries of ``v1`` encoded here must all be 1 (mod 3). Also the
   positions of these entries are linear independent when considered
   as Golay cocode vectors. From the corrsponding entries of ``v1``we
   compute a bit vector by setting the bits where the correspnding
   entry is 2 (mod 3). Multiplying that bit vector by the matrix in 
   part EQU_Y yields an element ``d`` of the Golay code, such that
   transforming the vector ``v`` with ``y_d`` yields a vector 
   in ``v1`` * \f$Q_{x0}\f$, with   \f$Q_{x0}\f$  of
   structure \f$2^{1+24}\f$.  In the sequel
   we assume that ``v`` is in that group.

   Part ``X`` contains a list of 24 entries of ``v1`` (in Leech
   lattice encoding) that are used to determine a
   transformation ``x_r = x_d * x_delta`` that transforms ``v`` to a
   vector in ``v`` * \f$x_{\pm 1}\f$. As above, a bit
   vector is computed from these 24 entries. The product of that bit
   vector  with the matrix EQU_X yields an element ``r`` in the Leech
   lattice mod2 (in Leech lattice encoding) so that ``v * x_r`` is
   equal to ``v1`` up to multiplication by \f$x_{\pm 1}\f$. The sign
   is obtained by inspecting the entry of  ``v * x_r`` encoded in
   part ``Z`` (im sparse notation).
*/
struct mm_order_data_Gx0_s {
    uint8_t WM[7];     ///< hash table for part 'A' of vector
    uint8_t Y[11][2];  ///< (Y[k,0],Y[k,1]) refers to 'A'[Y[k,0],Y[k,1]]
    uint32_t EQU_Y[11]; ///< matrix to solve equation for y_e
    uint32_t X[24];     ///< Vector entries in parts B, C, T, X in sparse notation
    uint32_t EQU_X[24]; ///< matrix to solve equation for x_r (mod x_{-1}
    uint32_t Z;         ///< Vector entriy in part Z on sparse notation
};


/**
   @brief typedef for structure ``struct mm_order_data_Gx0_s``
*/
typedef struct mm_order_data_Gx0_s  mm_order_data_Gx0_type;



/// @cond DO_NOT_DOCUMENT 
//  %%GEN c

/************************************************************************
** Tge structure for interpreting the standard oder vector
************************************************************************/

static mm_order_data_Gx0_type ORDER_DATA_STD = {
    {
       // %%TABLE V1_MOD3.HASH_A, uint8
    },
    {
       // %%TABLE V1_MOD3.EVAL_Y, uint8
    },
    {
       // %%TABLE V1_MOD3.EQU_Y, uint32
    },
    {
       // %%TABLE V1_MOD3.EVAL_X, uint32
    },
    {
       // %%TABLE V1_MOD3.EQU_X, uint32
    },
    0x0c000001UL 
};


/************************************************************************
** Order vector table
************************************************************************/



/**
 @brief Table containing the fixed vector \f$v_1\f$
 @hideinitializer

 The image \f$v_1 \cdot g\f$ of a fixed vector \f$v_1\f$ in the
 representation \f$\rho\f$ of the Monster under the action of an
 element \f$g\f$ of \f$G_{x0}\f$ can be used to determine \f$g\f$.
 The functions in this module support the computation of \f$g\f$
 from \f$v_1 \cdot g\f$. Here it suffices to know the entries
 of \f$v_1\f$ and of \f$v_1 \cdot g\f$ modulo 3.

 The following table contains a suitable vector \f$v_1\f$
 in *sparse representation*, preceded by a length indicator. Thus
 the length ``n`` of that representation is stored in entry 0 of
 the table, and the sparse representation of \f$v_1\f$ is
 stored in entries 1,...,n.
*/
// %%EXPORT_TABLE p
const  uint32_t MM_VECTOR_V1_MOD3_TABLE[] = {
 // %%TABLE V1_MOD3_VECTOR, uint32
};








/************************************************************************
** Load order vector
************************************************************************/



/** 
  @brief Load order vector from tables to a buffer

  The function stores the precomputed vector ``v_1`` (mod 3) into the
  array referred by ``p_dest``. That array must must be sufficiently
  long to store a vector of the representation  \f$\rho_{3}\f$.
 
*/
// %%EXPORT px
void mm_order_load_vector_v1_mod3(uint_mmv_t *p_dest)
{
    mm_aux_zero_mmv(3, p_dest);
    mm_aux_mmv_add_sparse(3, (uint32_t *)MM_VECTOR_V1_MOD3_TABLE + 1,
         MM_VECTOR_V1_MOD3_TABLE[0], p_dest);
}


/************************************************************************
** Check if a vector is equal to the order vector
************************************************************************/




/** 
  @brief Compare vector with precomputed order vector
  
  The function compares the vector \f$v\f$ in the
  representation \f$\rho_{3}\f$ of the monster group referred
  by ``v`` with the precomputed vector ``v_1``.

  The function returns 0 in case of equality and 1 otherwise.
  It destroys the vector in the buffer ``v``.
*/
// %%EXPORT px
int32_t mm_order_compare_v1_mod3(uint_mmv_t *v)
{
  /// @cond DO_NOT_DOCUMENT 
    #define MAXLEN_DATA 64
    uint32_t length = MM_VECTOR_V1_MOD3_TABLE[0], i, a[MAXLEN_DATA];
    if (length > MAXLEN_DATA) return -1;
    #undef MAXLEN_DATA
    for (i = 0; i < length; ++i) {
        a[i] = MM_VECTOR_V1_MOD3_TABLE[i+1] ^3;
    }
    mm_aux_mmv_add_sparse(3, a, length, v);
    return mm_op3_checkzero(v);
  /// @endcond 
}




/************************************************************************
** Error handling
************************************************************************/


/// @cond DO_NOT_DOCUMENT 

// #define _ERROR(source, error) (0 - (source << 16) - error)
#define _VAR_ERROR(source, res) \
    ((int32_t)(0 - (((source)+1) << 24) + ((int32_t)(res) & 0xffffffL)))

/// @endcond 


/************************************************************************
** Auxiliary functions for state machine
************************************************************************/

/// @cond DO_NOT_DOCUMENT 


static inline
int32_t watermark_to_perm(
    uint32_t wm[24], uint32_t y_sp[11], uint8_t wm_ref[7], uint8_t y[11][2])
{
   uint8_t pi[32], i, j, acc = 0;
   uint32_t m;
   for (j = 0; j < 7; ++j) (pi[j] = 0xff);
   for (i = 0; i < 24; ++i) {
       m = wm[i];
       m = m >= 0x60 ? m - 0x60 : m;
       for (j = 0; j < 7; ++j) {
           if (m == wm_ref[j]) pi[j] = i; 
       }
   }
   pi[8] = pi[6];
   for (j = 0; j < 7; ++j) acc |= pi[j];
   if(acc & 0x80) return -2;
   if (mat24_perm_complete_heptad(pi) != 0) return -3;
   for (i = 0; i < 11; ++i) {
       y_sp[i] =  0x2000000 + (pi[y[i][0]] << 14) + (pi[y[i][1]] << 8);
   }
   return mat24_perm_to_m24num(pi);
}


static inline
int32_t solve_y(uint32_t *data, uint32_t *equ_y)
{
    uint32_t err = 2, v_y = 0, k, y;
    for (k = 0; k < 11; ++k) {
        err &= data[k] + 1,
        v_y |= (data[k] & 2) << k;
    }
    if (err != 2) return -4;
    v_y >>= 1;
    y = leech2matrix_solve_eqn(equ_y, 11, v_y);
    return y;
}

static inline
int32_t prep_x(uint32_t *g, uint32_t len_g, uint32_t data[24], uint32_t *eval_x)
{
    uint32_t g_inv[12], i, signs = 0;
    int32_t res;
    for (i = 0; i < 24; ++i)  data[i] = eval_x[i];
    if (len_g > 12) return -5;
    for (i = 0; i < len_g; ++i) g_inv[i] = g[len_g - 1 - i] ^ 0x80000000UL;
    res = gen_leech2_op_word_many(data, 24, g_inv, len_g);
    if (res < 0) return res;
    if ((uint32_t)res != len_g) return -5;
    for (i = 0; i < 24; ++i) {
        signs += ((data[i] >> 24) & 1) << i;
        data[i] = res = mm_aux_index_leech2_to_sparse(data[i]) & 0xffffff00;
        if (res <= 0) return res ? res : -6;
    }
    return signs;
}

static inline
int32_t solve_x(uint32_t *data, uint32_t signs, uint32_t *equ_x)
{
    uint32_t err = 2, v_x = 0, k, x;
    for (k = 0; k < 24; ++k) {
        err &= data[k] + 1,
        v_x |= (data[k] & 2) << k;
    }
    if (err != 2) return -4;
    v_x >>= 1;
    v_x ^= signs;
    x = leech2matrix_solve_eqn(equ_x, 24, v_x);
    return x;
}


static inline
int32_t prep_sign(uint32_t *g, uint32_t len_g, uint32_t data[], uint32_t vz)
{
    uint32_t g_inv[12], i, signs = 0;
    int32_t res;
    if (len_g > 12) return -5;
    for (i = 0; i < len_g; ++i) g_inv[i] = g[len_g-1-i] ^ 0x80000000;
    uint64_t rep[14], z = 1ULL;
    if ((vz >> 26) != 3) return -12;
    z <<= 24 * ((vz >> 1) & 1) + ((vz >> 8) & 0x1f);
    xsp2co1_rep_mod3_unit_vector((uint32_t)((vz>>14) & 0xfff), z, rep);
    res = xsp2co1_rep_mod3_mul_word(rep, g_inv, len_g);
    if (res < 0) return -11;
    res = xsp2co1_rep_mod3_find_nonzero(rep);
    if (res < 0) return res;
    signs = (res >> 1) & 1;
    data[0] = res & 0xffffff00;
    return signs;
}

static inline
int32_t solve_sign(uint32_t *data, uint32_t signs)
{
    if (((data[0] + 1) & 2) != 2) return -4;
    return ((data[0] >> 1) ^ signs) & 1;
}

/// @endcond 





/************************************************************************
** State machine for finding element of G_x0 from a vector v_1
************************************************************************/



/** 
  @brief State machine for finding an element of the group \f$G_{x0}\f$ 

  The operation of the state machine is documented in the header
  of this file.
*/
// %%EXPORT
int32_t mm_order_find_Gx0_v1_mod3_state( mm_order_find_Gx0_type *st, int32_t state)
{
    int32_t res;
    uint32_t y, x, i;
    switch(state) {
        case 0:
            st->length = st->len_g = 0;
            st->state = 1;
            st->pdata = &ORDER_DATA_STD;
            return 0;
        case 1:
            if (state != st->state) return (st->state = _VAR_ERROR(1, -1));
            st->len_g = res = gen_leech2_reduce_type4(st->data[0], st->g);
            if (res < 0) return  (st->state = _VAR_ERROR(2, res));
            for (i = 0; i < st->len_g; ++i) st->data[i] = st->g[i];
            st->length = st->len_g;
            st->state = 2;
            return 0;
        case 2:
            if (state != st->state) return (st->state = _VAR_ERROR(1, -2));
            uint32_t perm_num = res = watermark_to_perm(
                 st->data, st->data, st->pdata->WM, st->pdata->Y);
            if (res < 0) return  (st->state =_VAR_ERROR(3, res));
            if (perm_num) st->g[st->len_g++] = 0xA0000000UL + perm_num;
            st->length = 11;
            st->state = 3;
            return 0;
        case 3:
            if (state != st->state) return (st->state = _VAR_ERROR(1, -3));
            y = res = solve_y(st->data, st->pdata->EQU_Y);
            if (res < 0) return _VAR_ERROR(4, res);
            if (y > 0) st->g[st->len_g++] = 0xC0000000 + y;
            st->signs = res = prep_x(st->g, st->len_g, st->data, st->pdata->X);
            if (res < 0) return _VAR_ERROR(5, res);
            st->length = 24;
            st->state = 4;
            return 0;
        case 4:
            if (state != st->state) return (st->state = _VAR_ERROR(1, -4));
            x = res = solve_x(st->data, st->signs, st->pdata->EQU_X);
            if (res < 0) return _VAR_ERROR(7, res);
            x ^= mat24_ploop_theta(x >> 12);
            if (x & 0xfff)  st->g[st->len_g++] = 0x90000000 + (x & 0xfff);
            x = (x >> 12) & 0x1fff;
            st->g[st->len_g++] = 0xB0000000 + x;
            st->signs = res = prep_sign(st->g, st->len_g, st->data, st->pdata->Z);
            if (res < 0) return _VAR_ERROR(8, res);
            st->length = 1;
            st->state = 5;
            return 0;
        case 5:
            if (state != st->state) return (st->state = _VAR_ERROR(1, -5));
            st->signs = res = solve_sign(st->data, st->signs);
            if (res < 0) return _VAR_ERROR(9, res);
            st->g[st->len_g - 1] ^= st->signs << 12;
            if ((st->g[st->len_g - 1] & 0x1fff) == 0) --st->len_g;
            for (i = 0; i < st->len_g; ++i) st->data[i] = st->g[i];
            st->length = st->len_g;
            st->state = 6;
            return 0;
        default:
            if (st->state < 0) return st->state;
            return (st->state = _VAR_ERROR(1, -6));
    }
}


/************************************************************************
** Initialize state machine for a different vector v_1
************************************************************************/

/** 
  @brief Initialize state machine for a different vector ``v_1``
 

  In case ``pdata == NULL`` this function is equivalent
  to ``mm_order_find_Gx0_v1_mod3_state(st, 0)``. In future extensions,
  the same calculation as in the state machine operated by
  function ``mm_order_find_Gx0_v1_mod3_state`` may also be performed
  for a vector ``v_2`` instead of a vector ``v_1``. Then the user must
  call ``mm_order_find_Gx0_v1_mod3_init(st, &data)`` instead of
  of ``mm_order_find_Gx0_v1_mod3_state(st, 0)`` for initializing the
  state machine. Here ``data`` must be a structure  of
  type ``mm_order_data_Gx0_type`` that is suitable for dealing
  with ``v_2`` instead of ``v_1``.
*/
// %%EXPORT
void mm_order_find_Gx0_v1_mod3_init( mm_order_find_Gx0_type *st, mm_order_data_Gx0_type *pdata)
{
     st->length = st->len_g = 0;
     st->state = 1;
     st->pdata = (pdata == NULL) ? &ORDER_DATA_STD : pdata;
}

/************************************************************************
** Auxiliary functions for function mm_order_find_Gx0_via_v1_mod3
************************************************************************/


/// @cond DO_NOT_DOCUMENT 

static inline void watermark_A(uint64_t *A, uint32_t wm[24])
{
    uint64_t d, s;
    uint32_t i;
    for (i = 0; i < 24; ++i) {
        s = A[i];
        d = (s >> (2*i)) & 3;
        s = (s ^ (s >> 1)) & 0x555555555555;
        s = (s + (s >> 2)) & 0x333333333333;
        s = (s + (s >> 4)) & 0x0F0F0F0F0F0F;
        s += s >> 8;
        s += s >> 16;
        s += s >> 32;
        wm[i] = (uint32_t)((d << 5) + (s & 0x1f));
    }
}

/// @endcond

/************************************************************************
** Find element of G_x0 from image of vector v_0 (mod 3)
************************************************************************/


/** 
  @brief Find an element \f$g\f$ of the group \f$G_{x0}\f$ 

  The function computes the element ``g**-1`` of the
  subgroup \f$G_{x0}\f$ of the Monster from a vector ``v = v_1 * g``.
  Here ``v_1`` is as described in the header of this file. Vector ``v``
  must be given as a vector in the representation \f$\rho_3\f$ of the
  Monster as in the description of the ``mmgroup.mm_op`` extension.
  The element ``g**-1`` is returned as a word of generators in the
  array ``g`` as  described in file ``mmgroup_generators.h``. The
  function returns the  length of element ``g**-1`` in case of success,
  and a negative value in case failure.

  Buffer ``g`` must have length at least 10.
*/
// %%EXPORT px
int32_t mm_order_find_Gx0_via_v1_mod3(uint_mmv_t *v,  uint32_t *g)
{
    mm_order_find_Gx0_type s;
    int32_t res;

    if ((res = mm_order_find_Gx0_v1_mod3_state(&s, 0)) < 0) return res;
    uint64_t w3 = mm_op3_eval_A_rank_mod3(v, 0);
    if ((w3 >> 48) != 23 || (w3 & 0xffffffffffffULL) == 0)
         return _VAR_ERROR(10, -11);
    s.data[0] = (uint32_t)(gen_leech3to2_type4(w3));
    if (s.data[0] == 0) return _VAR_ERROR(10, -12);

    if ((res = mm_order_find_Gx0_v1_mod3_state(&s, 1)) < 0) return res;
    uint64_t A[24];
    uint32_t i;
    for (i = 0; i < 24; ++i) A[i] = v[i];
    res = mm_op3_word_tag_A(A, s.data, s.length, 1);
    if (res < 0) return _VAR_ERROR(11, res);
    watermark_A(A, s.data);

    if ((res = mm_order_find_Gx0_v1_mod3_state(&s, 2)) < 0) return res;
    mm_aux_mmv_extract_sparse(3, A, s.data, s.length);

    if ((res = mm_order_find_Gx0_v1_mod3_state(&s, 3)) < 0) return res;
    mm_aux_mmv_extract_sparse(3, v, s.data, s.length);

    if ((res = mm_order_find_Gx0_v1_mod3_state(&s, 4)) < 0) return res;
    mm_aux_mmv_extract_sparse(3, v, s.data, s.length);

    if ((res = mm_order_find_Gx0_v1_mod3_state(&s, 5)) < 0) return res;
    for (i = 0; i < s.length; ++i) g[i] = s.data[i];
    return s.length;
}






//  %%GEN h
/// @endcond 
//  %%GEN c
